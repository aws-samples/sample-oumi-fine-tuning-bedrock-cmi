{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBedrockAssumeRole",
      "Effect": "Allow",
      "Principal": {
        "Service": "bedrock.amazonaws.com"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "<ACCOUNT_ID>"
        },
        "ArnLike": {
          "aws:SourceArn": "arn:aws:bedrock:<REGION>:<ACCOUNT_ID>:model-import-job/*"
        }
      }
    }
  ]
}
